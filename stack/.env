# THE INCIDENT KNOB — the walkthrough's bad deploy halves this to 10:
#   POOL_SIZE=10 docker compose up -d payment
POOL_SIZE=20

# Open-loop request rate from the load generator.
# Tuned so DB demand (~90% of requests × 0.35s hold) sits BETWEEN pool-10
# capacity (~28 req/s) and pool-20 capacity (~57 req/s): healthy at 20,
# saturated at 10.
LOAD_RPS=40
