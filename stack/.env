# THE INCIDENT KNOB — the walkthrough's bad deploy halves this to 10:
#   POOL_SIZE=10 docker compose up -d payment
POOL_SIZE=20

# Open-loop request rate from the load generator.
# Tuned (with CHARGE_DB_SECONDS) so DB demand (~90% of requests × ~0.65s hold
# ≈ 14 connections) sits BETWEEN pool-10 capacity (~15 req/s) and pool-20
# capacity (~31 req/s): healthy at 20, saturated at 10 — while the whole
# stack still fits a 2 GB Docker VM.
LOAD_RPS=24

# How long each captured charge holds a pooled DB connection (pg_sleep).
CHARGE_DB_SECONDS=0.6
